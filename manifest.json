{
  "manifest_version": 3,
  "name": "Clash Cleaner",
  "version": "1.0.0",
  "description": "Removes boilerplate code from CodinGame IDE.",
  "permissions": [
    "activeTab",
    "scripting"
  ],
  "background": {
    "service_worker": "dist/background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.codingame.com/*",
        "*://*.codingame-app.com/*"
      ],
      "js": [
        "dist/content.js"
      ],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "dist/page_script.js"
      ],
      "matches": [
        "*://*.codingame.com/*",
        "*://*.codingame-app.com/*"
      ]
    }
  ]
}
