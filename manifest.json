{
  "manifest_version": 3,
  "name": "Clash Cleaner",
  "version": "1.0.0",
  "description": "Removes boilerplate code from CodinGame IDE.",
  "permissions": [
    "activeTab",
    "scripting"
  ],
  "content_scripts": [
    {
      "matches": [
        "*://*.codingame.com/*"
      ],
      "js": [
        "dist/content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "dist/page_script.js"
      ],
      "matches": [
        "*://*.codingame.com/*"
      ]
    }
  ]
}
